  retailerProfile   RetailerProfile @relation(fields: [retailerProfileId], references: [id], onDelete: Cascade)

  @@index([retailerProfileId])
}

// ─── Order ────────────────────────────────────────────────────────────────────

enum OrderStatus {
  PAYMENT_PENDING     // Buyer placed order, payment not yet confirmed
  PAYMENT_FAILED      // Gateway reported failure
  PAYMENT_CAPTURED    // Payment received — awaiting admin confirmation
  CONFIRMED           // Admin verified — order is real, handed to sellers
  PROCESSING          // At least one seller is preparing items
  SHIPPED             // All items shipped
  OUT_FOR_DELIVERY    // In transit / last-mile
  DELIVERED           // Buyer received
  CANCELLED           // Terminal — cancelled by buyer/seller/admin
  RETURN_IN_PROGRESS  // Buyer requested return (denormalized flag)
  COMPLETED           // Terminal — all settled, no return window
}

enum CancelledBy {
  BUYER
  SELLER
  ADMIN
  SYSTEM
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique  // Human-readable: MG-20250401-001234
  retailerProfileId String

  status          OrderStatus @default(PAYMENT_PENDING)

  // Amount breakdown (denormalized — frozen at order time)
  subtotal        Decimal     @db.Decimal(10, 2)
  tax             Decimal     @db.Decimal(10, 2) @default(0)
  shippingCharge  Decimal     @db.Decimal(10, 2) @default(0)
  discount        Decimal     @db.Decimal(10, 2) @default(0)
  total           Decimal     @db.Decimal(10, 2)

  // Shipping address frozen at order time (JSON snapshot — immutable)
  shippingAddress Json        // AddressSnapshot: { name, line1, city, state, pincode, phone }

  // Cancel info
  cancelledAt     DateTime?
  cancelledBy     CancelledBy?
  cancellationNote String?

  // Key lifecycle timestamps
  confirmedAt     DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  completedAt     DateTime?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  retailerProfile RetailerProfile      @relation(fields: [retailerProfileId], references: [id])
  items           OrderItem[]
  payment         Payment?
  statusHistory   OrderStatusHistory[]
  returnRequests  ReturnRequest[]

  @@index([retailerProfileId, status])
  @@index([status])
  @@index([orderNumber])
}

// ─── OrderItem ────────────────────────────────────────────────────────────────
// One row per SKU per seller. Fulfillment and earnings tracked at item level.

model OrderItem {
  id                String        @id @default(cuid())
  orderId           String
  sellerProductId   String
  liveProductId     String
  sellerProfileId   String        // Denormalized — avoids join when listing seller's jobs

  // Product snapshot — frozen at order time so price changes don't affect history
  productTitle      String
  brand             String
  modelName         String
  partName          String
  condition         PartCondition
  unitPrice         Decimal       @db.Decimal(10, 2)
  quantity          Int
  totalPrice        Decimal       @db.Decimal(10, 2)   // unitPrice × quantity

  // Fulfillment (per-item — different sellers ship independently)
  trackingNumber    String?
  courierName       String?
  shippedAt         DateTime?
  deliveredAt       DateTime?

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  order             Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sellerProduct     SellerProduct @relation(fields: [sellerProductId], references: [id])
  liveProduct       LiveProduct   @relation(fields: [liveProductId], references: [id])
  sellerProfile     SellerProfile @relation(fields: [sellerProfileId], references: [id])
  earning           SellerEarning?
  returnItems       ReturnItem[]

  @@index([orderId])
  @@index([sellerProfileId])
  @@index([sellerProductId])
}

model OrderStatusHistory {
  id         String       @id @default(cuid())
  orderId    String
  fromStatus OrderStatus?
  toStatus   OrderStatus
  // Format: "BUYER:uid" | "SELLER:profileId" | "ADMIN:uid" | "SYSTEM"
  actor      String
  note       String?
  createdAt  DateTime     @default(now())

  order      Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// ─── Payment ──────────────────────────────────────────────────────────────────

enum PaymentStatus {
  PENDING
  CAPTURED
  PARTIALLY_REFUNDED
  FULLY_REFUNDED
  FAILED
}

enum PaymentMethod {
  UPI
  BANK_TRANSFER
  CARD
  WALLET
  COD
}

model Payment {
  id               String        @id @default(cuid())
  orderId          String        @unique

  status           PaymentStatus @default(PENDING)
  method           PaymentMethod
  amount           Decimal       @db.Decimal(10, 2)

  // Payment gateway fields (e.g. Razorpay)
  gatewayOrderId   String?
  gatewayPaymentId String?
  gatewaySignature String?

  capturedAt       DateTime?
  failedAt         DateTime?
  failureReason    String?

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  order            Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  refunds          Refund[]

  @@index([gatewayOrderId])
  @@index([status])
}

// ─── Return Module ────────────────────────────────────────────────────────────

enum ReturnStatus {
  REQUESTED          // Buyer submitted request
  APPROVED           // Admin approved — pickup to be scheduled
  REJECTED           // Admin rejected
  PICKUP_SCHEDULED   // Logistics booked
  PICKED_UP          // Courier collected items
  RECEIVED           // Seller/warehouse received items
  CLOSED             // Terminal — refund issued or rejected after receipt
}

enum ReturnReason {
  WRONG_ITEM
  DAMAGED_IN_TRANSIT
  NOT_AS_DESCRIBED
  DEFECTIVE
  CHANGED_MIND
  OTHER
}

model ReturnRequest {
  id             String       @id @default(cuid())
  orderId        String
  retailerProfileId String

  reason         ReturnReason
  description    String?

  status         ReturnStatus @default(REQUESTED)
  reviewedAt     DateTime?
  reviewedById   String?      // Admin User.id
  rejectionNote  String?

  pickupScheduledAt DateTime?
  pickedUpAt       DateTime?
  receivedAt       DateTime?

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  order          Order           @relation(fields: [orderId], references: [id])
  items          ReturnItem[]
  refund         Refund?
  statusHistory  ReturnStatusHistory[]

  @@index([orderId])
  @@index([retailerProfileId, status])
  @@index([status])
}

model ReturnItem {
  id              String        @id @default(cuid())
  returnRequestId String
  orderItemId     String
  quantity        Int

  // Admin fills in after receiving
  receivedCondition String?     // e.g. "As described", "Damaged", "Tampered"

  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  orderItem       OrderItem     @relation(fields: [orderItemId], references: [id])
}

model ReturnStatusHistory {
  id              String       @id @default(cuid())
  returnRequestId String
  fromStatus      ReturnStatus?
  toStatus        ReturnStatus
  actor           String       // "BUYER:uid" | "ADMIN:uid" | "SYSTEM"
  note            String?
  createdAt       DateTime     @default(now())

  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)

  @@index([returnRequestId])
}

// ─── Refund ───────────────────────────────────────────────────────────────────

enum RefundStatus {
  INITIATED
  PROCESSING
  COMPLETED
  FAILED
}

model Refund {
  id              String       @id @default(cuid())
  paymentId       String
  returnRequestId String?      @unique  // null = direct refund on pre-ship cancel

  amount          Decimal      @db.Decimal(10, 2)
  status          RefundStatus @default(INITIATED)

  // Gateway
  gatewayRefundId String?

  initiatedAt     DateTime     @default(now())
  processedAt     DateTime?
  completedAt     DateTime?
  failedAt        DateTime?
  failureReason   String?

  payment         Payment       @relation(fields: [paymentId], references: [id])
  returnRequest   ReturnRequest? @relation(fields: [returnRequestId], references: [id])

  @@index([paymentId])
}

// ─── Seller Earnings & Payouts ────────────────────────────────────────────────

enum EarningStatus {
  PENDING    // Order placed, payment not yet confirmed
  ON_HOLD    // Payment confirmed — T+7 hold period starts
