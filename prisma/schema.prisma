// ─── KYC ──────────────────────────────────────────────────────────────────────

enum KycStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  EDIT_REQUESTED  // Seller requested permission to edit approved KYC
  EDIT_UNLOCKED   // Admin approved the edit request — seller may resubmit
}

enum KycDocumentType {
  GST
  AADHAAR_PAN
}

model KycSubmission {
  id              String          @id @default(cuid())
  sellerProfileId String          @unique

  documentType    KycDocumentType @default(AADHAAR_PAN)
  gstNumber       String?
  aadhaarNumber   String?
  aadhaarImageUrl String?
  aadhaarPublicId String?         // Cloudinary public_id — used for deletion on re-submit
  panNumber       String?
  panImageUrl     String?
  panPublicId     String?

  status          KycStatus       @default(SUBMITTED)
  rejectionReason String?
  reviewedAt      DateTime?
  reviewedById    String?         // Admin User.id

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  sellerProfile   SellerProfile   @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)

  @@index([status])
