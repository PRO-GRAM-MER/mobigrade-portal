// ─── Catalog ───────────────────────────────────────────────────────────────────

enum CategoryType {
  SPARE_PARTS
  VRP
  NEW_PHONES
  PREXO
  OPEN_BOX
}

enum PartCondition {
  NEW           // Brand new, original manufacturer
  OEM           // Original Equipment Manufacturer (pulled from device)
  AFTERMARKET   // Third-party compatible part
  REFURBISHED   // Tested & restored used part
}

enum DraftStatus {
  DRAFT           // Invalid CSV row stored for reference — not reviewable
  PENDING_REVIEW  // Submitted, awaiting admin action
  APPROVED        // Listed on marketplace
  REJECTED        // Admin rejected with reason
  NEEDS_CHANGES   // Admin requested edits before approval
}

enum BatchStatus {
  PROCESSING      // Server is creating draft rows
  VALIDATED       // All rows valid
  PARTIALLY_VALID // Mix of valid + invalid rows
  FAILED          // All rows invalid or parse error
  SUBMITTED       // Seller confirmed and valid rows sent for review
}

// ─── Brand / Model master tables (seeded by admin) ───────────────────────────

model Brand {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  models    Model[]
}

model Model {
  id        String   @id @default(cuid())
  brandId   String
  name      String
  slug      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, name])
  @@index([brandId])
}

// Lookup table — seeded by admin, not created by sellers
model SparePartCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  drafts          CatalogProductDraft[]
  sellerProducts  SellerProduct[]
}

// Groups a single CSV upload — 1 CSV file = 1 batch
model CatalogUploadBatch {
  id              String      @id @default(cuid())
  sellerProfileId String
  filename        String
  status          BatchStatus @default(PROCESSING)
  totalRows       Int
  validRows       Int         @default(0)
  errorRows       Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  sellerProfile   SellerProfile         @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
  drafts          CatalogProductDraft[]

  @@index([sellerProfileId])
  @@index([status])
}

// One product listing — sourced from CSV or manual form
model CatalogProductDraft {
  id              String       @id @default(cuid())
  sellerProfileId String

  // Which product category this draft belongs to
  categoryType    CategoryType @default(SPARE_PARTS)

  batchId         String?      // null = manual entry
  rowNumber       Int?         // CSV row number for traceability (1-indexed, header excluded)

  // Shared core fields (always populated regardless of category)
  brand           String
  modelName       String
  price           Decimal      @db.Decimal(10, 2)
  quantity        Int

  // Spare-parts–specific fields (null for phone categories)
  partName        String?
  partNumber      String?
  categoryId      String?      // → SparePartCategory (spare-parts sub-category)
  condition       PartCondition?

  // Phone-category–specific fields stored as JSON
  // Keys mirror each CategoryConfig's field.key values
  specs           Json?

  description     String?

  // Images (Cloudinary secure_url array)
  imageUrls       String[]

  // Stored per-row validation errors — populated for DRAFT (invalid) rows
  rowErrors       Json?        // { field: string; message: string }[]

  status          DraftStatus @default(DRAFT)
  rejectionReason String?
  reviewedAt      DateTime?
  reviewedById    String?      // Admin User.id

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  sellerProfile   SellerProfile        @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
  batch           CatalogUploadBatch?  @relation(fields: [batchId], references: [id], onDelete: SetNull)
  category        SparePartCategory?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  sellerProduct   SellerProduct?

  @@index([sellerProfileId, categoryType, status])
  @@index([sellerProfileId, status])
  @@index([batchId])
  @@index([categoryType, status])
}

// ─── Admin Review Layer ────────────────────────────────────────────────────────
// SellerProduct: created when admin APPROVES a draft.
//   → "Seller DB" side — immutable approval snapshot owned by seller.
//
// LiveProduct: created when admin ENRICHES and PUBLISHES a SellerProduct.
//   → "Website DB" side — SEO-ready, admin-curated, visible to buyers.
//   → Extractable to a separate Neon project by swapping LiveProductPrismaClient
//     to a different DATABASE_URL_LIVE without any schema change.

enum SellerProductStatus {
  ACTIVE        // Approved, pending admin enrichment
  ENRICHING     // Admin is actively working on enrichment
  LIVE          // LiveProduct is PUBLISHED — visible on marketplace
  PAUSED        // Temporarily hidden (seller or admin request)
  DISCONTINUED  // Permanently removed
}

enum LiveProductStatus {
  DRAFT         // Being enriched by admin, not yet public
  PUBLISHED     // Live and visible on marketplace website
  ARCHIVED      // Removed from public listing
}

enum NotificationType {
  DRAFT_SUBMITTED
  DRAFT_APPROVED
  DRAFT_REJECTED
  DRAFT_NEEDS_CHANGES
  KYC_SUBMITTED
  KYC_APPROVED
  KYC_REJECTED
  ORDER_CONFIRMED
  ORDER_SHIPPED
  ORDER_DELIVERED
  ORDER_CANCELLED
  RETURN_APPROVED
  RETURN_REJECTED
  REFUND_PROCESSED
}

// ─── SellerProduct ────────────────────────────────────────────────────────────

model SellerProduct {
  id              String              @id @default(cuid())
  draftId         String              @unique  // source — immutable link to origin
  sellerProfileId String
  categoryId      String?

  // Which product category this product belongs to
  categoryType    CategoryType        @default(SPARE_PARTS)

  // Snapshot of approved draft — never mutated after creation
  brand           String
  modelName       String
  partName        String?             // null for phone categories
  partNumber      String?
  condition       PartCondition?      // null for phone categories
  specs           Json?               // mirrors CatalogProductDraft.specs
  sellerPrice     Decimal             @db.Decimal(10, 2)  // seller's submitted price
  quantity        Int
  description     String?
  imageUrls       String[]            // seller-provided images

  status          SellerProductStatus @default(ACTIVE)
  approvedAt      DateTime            @default(now())
  approvedById    String              // Admin User.id — audit trail

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  draft           CatalogProductDraft @relation(fields: [draftId], references: [id])
  sellerProfile   SellerProfile       @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
  category        SparePartCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  liveProduct     LiveProduct?
  orderItems      OrderItem[]

  @@index([sellerProfileId, categoryType, status])
  @@index([sellerProfileId, status])
  @@index([status])
  @@index([approvedById])
}

