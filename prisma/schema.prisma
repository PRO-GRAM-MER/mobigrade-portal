  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  sellerProduct   SellerProduct     @relation(fields: [sellerProductId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]

  @@index([status])
  @@index([slug])
}

