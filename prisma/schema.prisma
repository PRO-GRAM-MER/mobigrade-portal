}

model RetailerAddress {
  id                String          @id @default(cuid())
  retailerProfileId String
  label             String          // "Office", "Warehouse", "Shop"
  recipientName     String
  line1             String
  line2             String?
  city              String
  state             String
  pincode           String
  phone             String
