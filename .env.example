# ─── MobiGrade Portal — Environment Variables Template ───────────────────────
# Copy to .env.local and fill in real values.
# This file is committed to git. NEVER put real secrets here.

# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&channel_binding=require"

# ─── Auth (NextAuth) ──────────────────────────────────────────────────────────
# Generate secret: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-generated-secret"

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
CLOUDINARY_FOLDER="mobigrade/seller-kyc"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."

# ─── Sentry Error Tracking ────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN="https://...@sentry.io/..."
SENTRY_ORG="your-org-slug"
SENTRY_PROJECT="mobigrade-portal"
SENTRY_AUTH_TOKEN="sntrys_..."
